{
  "info": {
    "name": "IMES API - Task 2.1 InternProfile",
    "description": "Test collection for InternProfile Management endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.1.0"
  },
  "item": [
    {
      "name": "0. Setup - Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login successful', function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status.code).to.equal('0000');",
              "    pm.environment.set('token', jsonData.data.token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@imes.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "1. Create InternProfile - Success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Profile created successfully', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status.code).to.equal('0000');",
              "    pm.expect(jsonData.data).to.have.property('id');",
              "    pm.environment.set('intern_id', jsonData.data.id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"intern1@fpt.edu.vn\",\n  \"fullName\": \"Nguyễn Văn A\",\n  \"phoneNumber\": \"0912345678\",\n  \"major\": \"Công nghệ thông tin\",\n  \"university\": \"Đại học FPT\",\n  \"gpa\": 3.5,\n  \"skills\": \"Java, Spring Boot, React, PostgreSQL\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/intern-profiles",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles"]
        }
      }
    },
    {
      "name": "2. Get InternProfile by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Profile retrieved', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.email).to.equal('intern1@fpt.edu.vn');",
              "    pm.expect(jsonData.data.status).to.equal('NEW');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/{{intern_id}}",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "{{intern_id}}"]
        }
      }
    },
    {
      "name": "3. Get All InternProfiles (Paginated)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Page response structure', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('content');",
              "    pm.expect(jsonData.data).to.have.property('totalElements');",
              "    pm.expect(jsonData.data.content).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles?page=1&size=10&sortBy=createdAt&order=DESC",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles"],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "size", "value": "10"},
            {"key": "sortBy", "value": "createdAt"},
            {"key": "order", "value": "DESC"}
          ]
        }
      }
    },
    {
      "name": "4. Search InternProfiles by Keyword",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Search results returned', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.content).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/search?keyword=FPT&page=1&size=10",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "search"],
          "query": [
            {"key": "keyword", "value": "FPT"},
            {"key": "page", "value": "1"},
            {"key": "size", "value": "10"}
          ]
        }
      }
    },
    {
      "name": "5. Get InternProfiles by Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Filtered by status', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.content).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/status/NEW?page=1&size=10",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "status", "NEW"],
          "query": [
            {"key": "page", "value": "1"},
            {"key": "size", "value": "10"}
          ]
        }
      }
    },
    {
      "name": "6. Update InternProfile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Profile updated', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.gpa).to.equal(3.7);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"gpa\": 3.7,\n  \"skills\": \"Java, Spring Boot, React, PostgreSQL, Docker, Kubernetes\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/intern-profiles/{{intern_id}}",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "{{intern_id}}"]
        }
      }
    },
    {
      "name": "7. Update Start Date",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Start date updated', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.startDate).to.equal('2026-02-15');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/{{intern_id}}/start-date?startDate=2026-02-15",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "{{intern_id}}", "start-date"],
          "query": [
            {"key": "startDate", "value": "2026-02-15"}
          ]
        }
      }
    },
    {
      "name": "8. Update End Date",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('End date updated', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.endDate).to.equal('2026-05-15');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/{{intern_id}}/end-date?endDate=2026-05-15",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "{{intern_id}}", "end-date"],
          "query": [
            {"key": "endDate", "value": "2026-05-15"}
          ]
        }
      }
    },
    {
      "name": "9. Update Status to ACTIVE",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Status updated to ACTIVE', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.status).to.equal('ACTIVE');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/{{intern_id}}/status?status=ACTIVE",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "{{intern_id}}", "status"],
          "query": [
            {"key": "status", "value": "ACTIVE"}
          ]
        }
      }
    },
    {
      "name": "10. Get Statistics Total",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Total count returned', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.be.a('number');",
              "    pm.expect(jsonData.data).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/statistics/total",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "statistics", "total"]
        }
      }
    },
    {
      "name": "11. Get by Email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Profile found by email', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.email).to.equal('intern1@fpt.edu.vn');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/email/intern1@fpt.edu.vn",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "email", "intern1@fpt.edu.vn"]
        }
      }
    },
    {
      "name": "12. Error - Duplicate Email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Email already exists error', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status.code).to.equal('1004');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"intern1@fpt.edu.vn\",\n  \"fullName\": \"Test User\",\n  \"phoneNumber\": \"0987654321\",\n  \"major\": \"IT\",\n  \"university\": \"FPT\",\n  \"gpa\": 3.0,\n  \"skills\": \"Testing\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/intern-profiles",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles"]
        }
      }
    },
    {
      "name": "13. Error - Invalid GPA",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Validation error for GPA', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status.code).to.equal('3001');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@fpt.edu.vn\",\n  \"fullName\": \"Test User\",\n  \"phoneNumber\": \"0987654321\",\n  \"major\": \"IT\",\n  \"university\": \"FPT\",\n  \"gpa\": 5.0,\n  \"skills\": \"Testing\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/intern-profiles",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles"]
        }
      }
    },
    {
      "name": "14. Delete InternProfile (Soft Delete)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Profile deleted', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status.code).to.equal('0000');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{base_url}}/intern-profiles/{{intern_id}}",
          "host": ["{{base_url}}"],
          "path": ["intern-profiles", "{{intern_id}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "intern_id",
      "value": "",
      "type": "string"
    }
  ]
}
