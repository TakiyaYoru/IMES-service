{
  "info": {
    "name": "IMES Mentor Assignment API",
    "description": "Complete API testing for Mentor Assignment Management (Task 2.2)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Login (Get Token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set('token', jsonData.data.token);",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Token extracted', function () {",
              "    pm.expect(jsonData.data.token).to.exist;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"admin@imes.com\", \"password\": \"admin123\"}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "1. Create Mentor Assignment (Success)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set('mentor_assignment_id', jsonData.data.id);",
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Assignment ID exists', function () {",
              "    pm.expect(jsonData.data.id).to.exist;",
              "});",
              "pm.test('Assignment status is PENDING', function () {",
              "    pm.expect(jsonData.data.assignmentStatus).to.equal('PENDING');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"mentorId\": 1, \"internProfileId\": 2, \"startDate\": \"2026-01-20\", \"endDate\": \"2026-06-20\"}"
        },
        "url": {
          "raw": "{{base_url}}/mentor-assignments",
          "host": ["{{base_url}}"],
          "path": ["mentor-assignments"]
        }
      }
    },
    {
      "name": "2. Get Mentor Assignment by ID",
      "event": [
        {
