<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="v1.2.0_create_mentor_assignments_table" author="dev">
        <createTable tableName="mentor_assignments">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="mentor_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="intern_profile_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="assignment_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="is_active" type="BOOLEAN" defaultValue="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_mentor_assignment_mentor_id" tableName="mentor_assignments">
            <column name="mentor_id"/>
        </createIndex>

        <createIndex indexName="idx_mentor_assignment_intern_id" tableName="mentor_assignments">
            <column name="intern_profile_id"/>
        </createIndex>

        <createIndex indexName="idx_mentor_assignment_status" tableName="mentor_assignments">
            <column name="assignment_status"/>
        </createIndex>

        <createIndex indexName="idx_mentor_assignment_is_active" tableName="mentor_assignments">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
