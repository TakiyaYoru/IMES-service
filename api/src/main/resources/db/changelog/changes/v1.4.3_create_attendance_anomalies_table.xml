<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.4.3_create_attendance_anomalies_table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="attendance_anomalies"/>
            </not>
        </preConditions>

        <createTable tableName="attendance_anomalies">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="intern_profile_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="anomaly_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="anomaly_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="resolved" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="attendance_anomalies"
                baseColumnNames="intern_profile_id"
                constraintName="fk_attendance_anomaly_intern_profile"
                referencedTableName="intern_profiles"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <createIndex indexName="idx_anomaly_date" tableName="attendance_anomalies">
            <column name="anomaly_date"/>
        </createIndex>

        <createIndex indexName="idx_anomaly_intern_date_type" tableName="attendance_anomalies">
            <column name="intern_profile_id"/>
            <column name="anomaly_date"/>
            <column name="anomaly_type"/>
        </createIndex>

        <createIndex indexName="idx_anomaly_active_date" tableName="attendance_anomalies">
            <column name="is_active"/>
            <column name="anomaly_date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="attendance_anomalies"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
