<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.3.0_create_attendances_table" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="attendances"/>
            </not>
        </preConditions>

        <createTable tableName="attendances">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="intern_profile_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="check_in_time" type="TIME"/>
            <column name="check_out_time" type="TIME"/>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="total_hours" type="DECIMAL(5,2)"/>
            <column name="notes" type="TEXT"/>
            <column name="approved_by" type="BIGINT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Add foreign key to intern_profiles -->
        <addForeignKeyConstraint
                baseTableName="attendances"
                baseColumnNames="intern_profile_id"
                constraintName="fk_attendance_intern_profile"
                referencedTableName="intern_profiles"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <!-- Add foreign key to users (approved_by) -->
        <addForeignKeyConstraint
                baseTableName="attendances"
                baseColumnNames="approved_by"
                constraintName="fk_attendance_approved_by"
                referencedTableName="users"
                referencedColumnNames="id"
                onDelete="SET NULL"/>

        <!-- Create indexes for better query performance -->
        <createIndex indexName="idx_attendance_intern_profile_id" tableName="attendances">
            <column name="intern_profile_id"/>
        </createIndex>

        <createIndex indexName="idx_attendance_date" tableName="attendances">
            <column name="date"/>
        </createIndex>

        <createIndex indexName="idx_attendance_status" tableName="attendances">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_attendance_is_active" tableName="attendances">
            <column name="is_active"/>
        </createIndex>

        <!-- Unique constraint: one attendance record per intern per date -->
        <addUniqueConstraint
                tableName="attendances"
                columnNames="intern_profile_id, date"
                constraintName="uk_attendance_intern_date"/>

        <rollback>
            <dropTable tableName="attendances"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
