<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="v1.1.0_create_intern_profiles_table" author="dev-team">
        <createTable tableName="intern_profiles">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="full_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone_number" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
            <column name="major" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="university" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="gpa" type="DECIMAL(3,2)">
                <constraints nullable="false"/>
            </column>
            <column name="skills" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="end_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="intern_profiles" indexName="idx_intern_email">
            <column name="email"/>
        </createIndex>

        <createIndex tableName="intern_profiles" indexName="idx_intern_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="intern_profiles" indexName="idx_intern_is_active">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
