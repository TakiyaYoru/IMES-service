{
  "info": {
    "name": "IMES - Assignment API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "assignmentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as Mentor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('token', response.data.token);",
                  "    console.log('Token saved:', response.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mentor@imes.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Assignments",
      "item": [
        {
          "name": "Create Assignment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success status', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status.code).to.equal('0000');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.id) {",
                  "        pm.collectionVariables.set('assignmentId', response.data.id);",
                  "        console.log('Assignment ID saved:', response.data.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot Advanced Topics\",\n  \"description\": \"Complete a Spring Boot project with JWT authentication, database integration, and REST APIs. Submit source code and documentation.\",\n  \"deadline\": \"2026-02-28T23:59:59\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"]
            }
          }
        },
        {
          "name": "Get Assignment by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has assignment data', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.have.property('id');",
                  "    pm.expect(response.data).to.have.property('title');",
                  "    pm.expect(response.data).to.have.property('deadline');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Update Assignment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Assignment updated successfully', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data.title).to.include('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Spring Boot Advanced Topics - Updated\",\n  \"description\": \"Updated description with additional requirements: implement caching and async processing.\",\n  \"deadline\": \"2026-03-15T23:59:59\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Get All Assignments (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has assignments array', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.be.an('object');",
                  "    pm.expect(response.data.content).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Assignments by Mentor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has mentor assignments', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments/mentor/7",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "mentor", "7"]
            }
          }
        },
        {
          "name": "Delete Assignment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Assignment deleted successfully', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status.code).to.equal('0000');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "{{assignmentId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Create Assignment - Invalid Deadline",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 or returns error', () => {",
                  "    pm.expect([400, 200]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Response has error code', () => {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.status.code).to.not.equal('0000');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Past Deadline Assignment\",\n  \"description\": \"This should fail\",\n  \"deadline\": \"2025-01-01T23:59:59\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"]
            }
          }
        },
        {
          "name": "Get Assignment - Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns error for non-existent assignment', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status.code).to.not.equal('0000');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments/99999",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "99999"]
            }
          }
        },
        {
          "name": "Update Assignment - Unauthorized",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns unauthorized error', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.status.code).to.not.equal('0000');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Trying to update someone else's assignment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments/1",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "1"]
            }
          }
        }
      ]
    }
  ]
}
