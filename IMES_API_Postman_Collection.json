  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Login - Admin (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has correct structure', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData).to.have.property('metaData');",
                  "});",
                  "pm.test('Status code is 0000 (success)', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status.code).to.equal('0000');",
                  "});",
                  "pm.test('Token is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.token).to.be.a('string');",
                  "    pm.expect(jsonData.data.token.length).to.be.greaterThan(0);",
                  "});",
                  "// Save token for subsequent requests",
                  "pm.environment.set('admin_token', pm.response.json().data.token);",
                  "pm.environment.set('admin_email', pm.response.json().data.email);",
                  "pm.environment.set('admin_role', pm.response.json().data.role);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@imes.com\",\"password\":\"admin123\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
